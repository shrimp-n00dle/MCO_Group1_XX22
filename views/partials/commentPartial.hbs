<div class="postCommentContainer">
    <div class="commentHeader">
        <img src="{{comment.profilePicture}}">
        <a href="/viewProfile/{{comment.username}}"><h3>{{comment.username}}</h3></a>
    </div>

    <div class="commentBody">
        <p> {{comment.body}} </p>

        <div class="commentFooter">
            <p class="commentLikeCount">{{comment.likeCount}}</p>
            <button type="submit" class="genButton-red">Like</button></a>
            <p class="commentCount">{{comment.commentCount}}</p>
            <button type="submit" class="genButton-red">Comment</button></a>
        </div>
    </div>
    <script src="/js/liking.js"></script>
</div>